# Configuración de line endings para el repositorio

# Archivos de scripts de Windows - mantener CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Archivos de scripts Unix - mantener LF
*.sh text eol=lf

# Archivos de virtualenv - tratarlos como binarios para no modificar line endings
.specnative/.venv/bin/* binary
.specnative/.venv/bin/Activate.ps1 binary

# Archivos de texto - convertir a LF
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.java text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf

# Archivos binarios - no modificar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.class binary